# Copiați ca .env (nu se versionează).
# Pe cPanel: plasați .env în afara public_html, ex. /home/aquamari1/.env

DB_HOST=127.0.0.1
DB_PORT=8889
DB_NAME=aquamarine
DB_USER=root
# MAMP: adesea root (gol sau „root” — verificați în phpMyAdmin)
# Parole cu # trebuie între ghilimele, ex. DB_PASS="abc#123"
DB_PASS=
DB_CHARSET=utf8mb4

MAIL_ENABLED=false
CONTACT_RECIPIENT_EMAIL=contact@aquamarine.md

# Analytics (opțional)
GTM_ID=
GA4_ID=

# Diagnostic web check_setup.php — true doar temporar pe server
ALLOW_SETUP_CHECK=false
