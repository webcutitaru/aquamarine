# Copiați pe server ca /home/aquamari1/.env (în afara public_html).

DB_HOST=localhost
DB_PORT=3306
DB_NAME=INLOCUITI_CU_NUMELE_DB_CPANEL
DB_USER=INLOCUITI_CU_USER_CPANEL
# Dacă parola conține # sau spații, folosiți ghilimele: DB_PASS="parola#completa"
DB_PASS=INLOCUITI_CU_PAROLA_CPANEL
DB_CHARSET=utf8mb4

MAIL_ENABLED=true
CONTACT_RECIPIENT_EMAIL=contact@aquamarine.md

# Analytics (opțional — lăsați gol dacă nu folosiți)
GTM_ID=
GA4_ID=

# Diagnostic web — lăsați false pe producție
ALLOW_SETUP_CHECK=false
